<Window
    x:Class="TermExample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TermExample"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:t="http://schemas.lepo.co/wpfui/2022/xaml/terminal"
    Title="Sample Term"
    Width="1200"
    Height="550"
    Background="{Binding BackroundColorBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <t:TerminalControl
            x:Name="basicTermControl"
            FontFamilyWhenSettingTheme="Consolas"
            InputCapture="TabKey,DirectionKeys"
            LogConPTYOutput="True"
            StartupCommandLine="{Binding StartupCommand}"
            Theme="{Binding Theme, Mode=OneWay}"
            Win32InputMode="True">
            <t:TerminalControl.Resources>
                <Style BasedOn="{StaticResource {x:Type ScrollBar}}" TargetType="ScrollBar">
                    <!--  Lazy Theming  -->
                    <Setter Property="Opacity" Value="0.7" />
                </Style>
            </t:TerminalControl.Resources>
        </t:TerminalControl>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="5"
                Click="DuplicateClicked"
                Content="Duplicate New" />
            <Button
                Margin="5"
                Click="ClearTermClicked"
                Content="Clear Term" />
            <Button
                Margin="5"
                Click="RestartTermClicked"
                Content="Restart Term" />
            <Button
                Margin="5"
                Click="ShowBufferClicked"
                Content="Show Buffer" />
            <Button
                Margin="5"
                Click="ShowProcessOutputClicked"
                Content="Process Output Sample" />
        </StackPanel>
    </Grid>
</Window>
